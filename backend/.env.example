# Configuración del proveedor de base de datos
# Opciones: postgresql, neon, supabase
DB_PROVIDER=postgresql

# URLs de conexión para diferentes proveedores
DATABASE_URL= # Para PostgreSQL tradicional
NEON_DATABASE_URL= # Para Neon
SUPABASE_DATABASE_URL= # Para Supabase

# Configuración general
NODE_ENV=development
PORT=5000

# JWT Secret para autenticación
JWT_SECRET=tu_secreto_jwt_aqui

# Variables de Supabase (para funcionalidades que aún usan Supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
BACKEND_SUPABASE_URL=
BACKEND_SUPABASE_PUBLISHABLE_KEY=

# Variables para Power Automate (si aplica)
POWER_AUTOMATE_WEBHOOK_URL=
