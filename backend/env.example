# Configuración del Servidor
PORT=5000
NODE_ENV=development

# Configuración de Base de Datos (PostgreSQL)
# Ejemplo para Neon, Supabase, RDS o Local Postgres
DATABASE_URL=postgresql://usuario:contraseña@host:puerto/nombre_base_de_datos?sslmode=require

# Seguridad y Autenticación JWT
JWT_SECRET=super_secret_jwt_key_form_cupos_2026
JWT_EXPIRES_IN=24h

# Secreto JWT de Supabase (Opcional, si el frontend sigue usando Supabase Auth)
# Permite a la API Express validar tokens emitidos por Supabase
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Integración con Power Automate (Flujos Externos)
POWERAUTOMATE_GET_URL=https://prod-XX.westus.logic.azure.com:443/workflows/...
POWERAUTOMATE_GET_REQUESTS_URL=https://prod-XX.westus.logic.azure.com:443/workflows/...
POWERAUTOMATE_GET_CONFIRMATIONS_URL=https://prod-XX.westus.logic.azure.com:443/workflows/...
POWERAUTOMATE_SUBMIT_URL=https://prod-XX.westus.logic.azure.com:443/workflows/...
