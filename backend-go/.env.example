PORT=5002
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname?sslmode=disable
JWT_SECRET=tu_clave_secreta_super_segura
JWT_EXPIRES_IN=24h

# URL del frontend para CORS (obligatorio en producción)
URL_FRONTEND=https://app-cupos-frontend.vercel.app

# Secreto para GET /api/cron/expire-reservations (header X-Cron-Secret).
# Configurar un cron externo (cron-job.org, GitHub Actions, etc.) cada 5-15 min.
CRON_SECRET=

# SMTP global de fallback, usado cuando una agencia no tiene su propio
# EmailSMTPConfig configurado desde /email-config
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=


